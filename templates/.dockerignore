# =============================================================================
# .dockerignore — Docker 构建忽略文件模板
# =============================================================================
# 用途：排除不需要进入 Docker 镜像的文件和目录，减小构建上下文大小，
#       加速构建过程，避免将敏感信息打包进镜像。
# 使用方式：将此文件放在项目根目录（与 Dockerfile 同级）
# =============================================================================

# ---------------------------------------------------------------------------
# 版本控制
# ---------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# ---------------------------------------------------------------------------
# 环境变量与敏感配置（绝对不能打包进镜像）
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local

# ---------------------------------------------------------------------------
# Node.js
# ---------------------------------------------------------------------------
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__
*.pyc
*.pyo
*.pyd
.Python
.venv
venv
env
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
.coverage
.coverage.*

# ---------------------------------------------------------------------------
# 构建产物（多阶段构建中由构建阶段生成，不需要在 COPY 时带入）
# ---------------------------------------------------------------------------
dist
build
.next
out
.nuxt
.output
.server
.svelte-kit

# ---------------------------------------------------------------------------
# IDE / 编辑器配置
# ---------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# 操作系统生成文件
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Docker 相关文件（不需要打包进镜像自身）
# ---------------------------------------------------------------------------
.dockerignore
Dockerfile
Dockerfile.*
docker-compose*.yml
docker-compose*.yaml
docker-compose*.env

# ---------------------------------------------------------------------------
# 文档与说明文件（生产镜像不需要）
# ---------------------------------------------------------------------------
*.md
LICENSE
CHANGELOG*
AUTHORS
CONTRIBUTING

# ---------------------------------------------------------------------------
# 测试与覆盖率
# ---------------------------------------------------------------------------
coverage
.nyc_output
test
tests
__tests__
spec
specs
e2e
cypress

# ---------------------------------------------------------------------------
# 临时文件与日志
# ---------------------------------------------------------------------------
tmp
temp
log
logs
*.log

# ---------------------------------------------------------------------------
# CI/CD 配置
# ---------------------------------------------------------------------------
.github
.gitlab-ci.yml
.circleci
Jenkinsfile

# ---------------------------------------------------------------------------
# 其他
# ---------------------------------------------------------------------------
.editorconfig
.eslintcache
.prettierrc
prettier.config.*
eslint.config.*
tsconfig*.json
